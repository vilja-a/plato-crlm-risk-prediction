ggtheme = theme_bw(), # customize plot and risk table with a theme.
risk.table = TRUE,  # absolute number and percentage at risk.
risk.table.y.text.col = T,# colour risk table text annotations.
risk.table.y.text = FALSE,# show bars instead of names in text annotations
ncensor.plot = T,      # plot the number of censored subjects at time t
surv.median.line = "hv",
xscale = 'd_y',
palette= 'Set1',
title=paste("Cox model for", covariate, ("hRFS")))
# Store the plot in the list
plot_list[[covariate]] <- ggsurv_plot
ggsave(file=paste("KM_hRFS_",covariate,".pdf",sep=""),
plot=ggarrange(plot_list[[covariate]]$plot, plot_list[[covariate]]$table,
nrow=2, ncol=1, heights=c(3,1)),
path = './results/Kaplan-Meier gp subset/')
}
# Print all the plots
for (plot in plot_list) {
print(plot)
}
sessionInfo()
shiny::runApp('/Volumes/projects-1/PhD project/OneDrive/Clinical Risk Scores 2025/App-1/my_app')
runApp('/Volumes/projects-1/PhD project/OneDrive/Clinical Risk Scores 2025/RiskScoreApp/CRS_app')
runApp('/Volumes/projects-1/PhD project/OneDrive/Clinical Risk Scores 2025/RiskScoreApp/CRS_app')
