histos <- pivot_longer(histos,
cols=colnames(histos),
names_to = 'variable',
values_to = 'value')
#table of cutoffs
cutoffs <- data.frame(cutoffs=c(5, 11, 23, 2, 4, 51, 31, 9, 4.9, 5.3, 61),
variable=c(rep('time_between_CRC_and_LM_months', 3), rep('MetCount', 2), 'LargMetSize_mm', 'MaxVit_percent', rep('ResectionMargin_mm', 2), 'preoperative_CEA_ugL', 'Age'))
h <- ggplot(histos, aes(x = value))+
geom_histogram(na.rm = T, bins = 20)+
geom_vline(data = cutoffs, mapping = aes(xintercept = cutoffs, colour = factor(cutoffs, levels = unique(cutoffs))), size = 1)+
scale_color_brewer(type='qual', palette = 'Paired', direction = -1)+
theme(legend.position="bottom")+
theme_clean()+
facet_wrap(~variable, scales = 'free', ncol = 7)
stacked2 <- pivot_longer(stacked2,
cols=colnames(stacked2),
names_to = 'variable',
values_to = 'value')
stacked2 <- stacked2%>%
mutate(facet_id=case_when(variable %in% c('S_DFI_6m','S_DFI_12m', 'S_DFI_24m') ~'time_between_CRC_and_LM_months',
variable %in% c('S_MetCount_1','S_MetCount_3') ~'MetCount',
variable %in% c('S_size') ~'LargMetSize_mm',
variable %in% c('S_vitality') ~'MaxVit_percent',
variable %in% c('S_margin_10','S_margin_5') ~'ResectionMargin_mm',
variable %in% c('S_preopCEA') ~'preoperative_CEA_ugL',
variable %in% c('S_Age') ~'Age'))
stacked2$value <- factor(stacked2$value, levels = as.character(c('1', '0')))
stacked2$variable <- factor(stacked2$variable, levels = as.character(c('S_Age', 'S_size', 'S_vitality', 'S_MetCount_1', 'S_MetCount_3',
'S_preopCEA', 'S_margin_5', 'S_margin_10', 'S_DFI_24m', 'S_DFI_12m', 'S_DFI_6m')))
s <- ggplot(data=stacked2, aes(x=variable, fill=value)) +
geom_bar()+
labs(x = 'Score variable', y='fraction of score values')+
scale_fill_brewer(type='qual', palette = 6, direction = -1)+
theme_clean()+
coord_flip()+
scale_y_reverse() +
facet_wrap(~facet_id, ncol =7, scales = 'free')
ggarrange(s,h, ncol =1)
# Compute scores
CRScores_complete <- CRScores_complete %>%
rowwise()%>%
mutate(Score_H=sum(S_pN_status, S_pT_status_T3_4, S_MetCount_1, S_margin_5, S_size, S_vitality, S_VascInv, S_BiliaryInv),
Score_mF = sum(S_pN_status, S_DFI_6m, S_MetCount_1, S_size, S_preopCEA),
Score_F=sum(S_pN_status, S_DFI_12m, S_MetCount_1, S_size, S_preopCEA),
Score_No=sum(S_pN_status, S_pT_status_T4, S_DFI_24m, S_MetCount_3, S_size, S_margin_10, S_Age),
Score_K=sum(S_MetCount_3, S_preopCEA, S_synchronous),
Score_Na2004=0.8375*S_pN_status+0.8057*S_pT_status_T4+1.4532*S_size+1.3957*S_resectiable_extrahepatic_mets+0.8609*S_MetCount_1,
Score_Na2006=0.60034*S_pN_status+ 0.54877*S_pT_status_T4+1.35657*S_size+1.19430*S_resectiable_extrahepatic_mets+0.67838*S_DFI_12m+0.85412*S_MetCount_1)%>%
data.frame()
# count strata
CRScores_complete <- CRScores_complete %>%
mutate(ScoreH_strata = case_when(Score_H <= 2~'0-2',
Score_H > 2 & Score_H <= 4~'3-4',
Score_H>4~'5-8'),
ScoremF_strata = case_when(Score_mF <= 1~'0-1',
Score_mF > 1 & Score_mF <= 3~'2-3',
Score_mF>3~'4-5'),
ScoreF_strata = case_when(Score_F<= 2~'0-2',
Score_F > 2 & Score_F <= 4~'3-4',
Score_H>4~'5'),
ScoreNo_strata = case_when(Score_No<= 2~'0-2',
Score_No > 2 & Score_No <= 4~'3-4',
Score_No>4~'5-7'),
ScoreK_strata = case_when(Score_K==0~'Low',
Score_K==1~'Intermediate',
Score_K>=2~'High'),
ScoreNa2004_strata = case_when(Score_Na2004<= 1~'Grade A',
Score_Na2004 > 1 & Score_Na2004 <= 3~'Grade B',
Score_Na2004>3~'Grade C'),
ScoreNa2006_strata = case_when(Score_Na2006<= 3~'Grade A',
Score_Na2006 > 3 & Score_Na2006 <= 5~'Grade B',
Score_Na2006>5~'Grade C'))%>%
data.frame()
CRScores_complete%>%
select(starts_with('Score'))%>%
summary()
# inspect relation ship of vascular and biliary invasion
# 1. Contingency Table
contingency_table <- table(CRScores_complete$S_VascInv, CRScores_complete$S_BiliaryInv)
print(contingency_table)
# 2. Chi-Square Test
chi_square_test <- chisq.test(contingency_table)
print(chi_square_test)
# 3. Phi Coefficient
abs(phi(contingency_table))
# very high correlation between these two values.
# create a combined variable for'biliary or vascular invasion'
CRScores_complete$S_BiliaryVascInv <- with(CRScores_complete, ifelse(S_BiliaryInv == 1 | S_VascInv == 1, 1, 0))
summary(CRScores_complete[, c('S_BiliaryVascInv', 'S_BiliaryInv', 'S_VascInv')])
table(CRScores_complete[, c('S_BiliaryVascInv', 'S_BiliaryInv')])
table(CRScores_complete[, c('S_BiliaryVascInv', 'S_VascInv')])
# inspect relation ship of vascular invasion and tumor status
# 1. Contingency Table
contingency_table <- table(CRScores_complete$S_pN_status, CRScores_complete$S_pT_status_T3_4)
print(contingency_table)
# 2. Chi-Square Test
chi_square_test <- chisq.test(contingency_table)
print(chi_square_test)
# 3. Phi Coefficient
abs(phi(contingency_table)) ## hmm how tumor stages are related to lymph node invasion?
# convert to factor
CRScores_survival<- CRScores_complete%>%
mutate(across(starts_with('S_'), ~factor(.x, levels=c('0', '1'))))
CRScores_survival <- CRScores_survival%>%
mutate(encapsulation_strata = factor(encapsulation_strata, levels= c( "[0,33]", "(33,99.9]", "(99.9,100]")),
ScoreH_strata = factor(ScoreH_strata, levels= c('0-2', '3-4', '5-8')),
ScoremF_strata = factor(ScoremF_strata, levels= c('0-1', '2-3', '4-5')),
ScoreF_strata=factor(ScoreF_strata, levels= c('0-2', '3-4', '5')),
ScoreNo_strata=factor(ScoreNo_strata, levels= c('0-2', '3-4', '5-7')),
ScoreK_strata=factor(ScoreK_strata, levels= c('Low', 'Intermediate', 'High')),
ScoreNa2004_strata=factor(ScoreNa2004_strata, levels= c('Grade A', 'Grade B', 'Grade C')),
ScoreNa2006_strata=factor(ScoreNa2006_strata, levels= c('Grade A', 'Grade B', 'Grade C')))%>%
data.frame()
head(CRScores_survival)
summary(CRScores_survival)
head(CRScores_survival)
CRScores_survival <- filter(CRScores_survival, !is.na(encapsulation_strata))
nrow(CRScores_survival)
#univariate with a loop
scores <- CRScores_survival%>%
select(starts_with('S_'), ends_with('strata'))%>%
colnames()
# UNI - OS
# Initialize a list to store the plots
plot_list <- list()
# Loop over each covariate column
for (covariate in colnames(CRScores_survival[,scores])) {  # Exclude time and status columns
# Fit the Cox proportional hazards model
formula <- as.formula(paste("Surv(OS, Death_status) ~", covariate))
cox_model <- coxph(formula, data = CRScores_survival)
# summary from the model
summary(cox_model)
# Create ggforest plot
ggforest_plot <- ggforest(cox_model,main = paste("Cox model for", covariate, "OS"))
# Store the plot in the list
plot_list[[covariate]] <- ggforest_plot
ggsave(plot_list[[covariate]],filename=paste("univariateOS_",covariate,".pdf",sep=""), path = './results/univariate gp subset/')
}
# Print all the plots
for (plot in plot_list) {
print(plot)
}
# UNI - RFS
# Initialize a list to store the plots
plot_list <- list()
# Loop over each covariate column
for (covariate in colnames(CRScores_survival[,scores])) {  # Exclude time and status columns
# Fit the Cox proportional hazards model
formula <- as.formula(paste("Surv(RFS, Progression_status) ~", covariate))
cox_model <- coxph(formula, data = CRScores_survival%>%filter(!RFS<0))
# summary from the model
summary(cox_model)
# Create ggforest plot
ggforest_plot <- ggforest(cox_model, main = paste("Cox model for", covariate, ("RFS")))
# Store the plot in the list
plot_list[[covariate]] <- ggforest_plot
ggsave(plot_list[[covariate]],filename=paste("univariateRFS_",covariate,".pdf",sep=""), path = './results/univariate gp subset/')
}
# Print all the plots
for (plot in plot_list) {
print(plot)
}
