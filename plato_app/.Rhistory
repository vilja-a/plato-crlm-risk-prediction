# Initialize a list to store the plots
plot_list <- list()
strata <- CRScores_survival%>%
select(ends_with('strata'))%>%
colnames()
# OS
# Loop over each covariate column
for (covariate in colnames(CRScores_survival[,strata])) {  # Exclude time and status columns
# Fit the Cox proportional hazards model
formula <- as.formula(paste("Surv(OS, Death_status) ~", covariate))
cox_model <- surv_fit(formula, data = CRScores_survival)
# summary from the model
summary(cox_model)
# Create ggforest plot
ggsurv_plot <- ggsurvplot(cox_model,
data = CRScores_survival,
xlab = "Time from resection",   # customize X axis label.
break.time.by = 365.25,     # break X axis in time intervals by 200.
pval = TRUE,
ggtheme = theme_bw(), # customize plot and risk table with a theme.
risk.table = TRUE,  # absolute number and percentage at risk.
risk.table.y.text.col = T,# colour risk table text annotations.
risk.table.y.text = FALSE,# show bars instead of names in text annotations
ncensor.plot = T,      # plot the number of censored subjects at time t
surv.median.line = "hv",
palette= 'Set1',
xscale = 'd_y',
title=paste("Cox model for", covariate, ("OS")))
# Store the plot in the list
plot_list[[covariate]] <- ggsurv_plot
#  ggsave(file=paste("KM_OS_",covariate,".pdf",sep=""), plot_list[[covariate]]$plot, path = './results/Kaplan-Meier/')
ggsave(file=paste("KM_OS_",covariate,".pdf",sep=""), plot=ggarrange(plot_list[[covariate]]$plot, plot_list[[covariate]]$table, nrow=2, ncol=1, heights=c(3,1)), path = './results/Kaplan-Meier gp subset/')
}
# Print all the plots
for (plot in plot_list) {
print(plot)
}
